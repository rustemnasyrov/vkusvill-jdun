# Для запуска через Docker основные переменные заданы в docker-compose.yml.
# Ниже — для опционального локального запуска без Docker.

DATABASE_URL=postgresql+asyncpg://courier:courier@localhost:5432/courier_shifts

ADMIN_USERNAME=master
ADMIN_PASSWORD=vkusvill
JWT_SECRET=dev-jwt-secret-change-me

# Опционально: один статический Bearer для скриптов/Swagger (без JWT)
# ADMIN_LEGACY_TOKEN=

DEFAULT_CANCEL_DEADLINE_HOURS=12
MAX_SHIFTS_PER_WEEK_PER_COURIER=50
MIN_HOURS_BETWEEN_SHIFTS=0
CORS_ORIGINS=http://localhost:9001,http://127.0.0.1:9001
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
